{
  "name": "nanoclaw",
  "version": "1.2.53",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.105",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@nanoclaw/agent-core": "workspace:*",
    "@onecli-sh/sdk": "^0.2.0",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0",
    "discord.js": "^14.18.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^146.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@typescript/native-preview": "7.0.0-dev.20260411.1",
    "husky": "^9.1.7",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.33.0"
}
